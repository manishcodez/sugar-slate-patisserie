PORT=3000
JWT_SECRET=change-this-to-a-long-random-secret-in-production
CLIENT_ORIGIN=http://localhost:5173
DATABASE_PATH=./data/sugar-slate.db

# Seed admin (created on first run if missing)
SEED_ADMIN_EMAIL=admin@sugarslate.com
SEED_ADMIN_PASSWORD=Admin@2026
SEED_ADMIN_NAME=Sugar & Slate Admin

# Razorpay — get keys from https://dashboard.razorpay.com/app/keys
# Use Test Mode keys first, then Live keys for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Email (optional) — order confirmation emails
# Gmail example: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_SECURE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Sugar & Slate <orders@sugarslate.com>

# Dev-only: return reset token in API response when SMTP is not configured
ALLOW_DEV_RESET=false
