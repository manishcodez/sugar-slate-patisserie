# Backend API base URL — set when your server is ready
VITE_API_BASE_URL=http://localhost:3000/api

# Razorpay Key ID is loaded from API /payments/config when server is configured.
# No frontend secret needed — only RAZORPAY_KEY_ID + RAZORPAY_KEY_SECRET in server/.env

# Optional: Formspree fallback for contact form when API is offline
# VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id

# Optional: existing admin email / JSONBin config (if used)
# VITE_WEB3FORMS_ACCESS_KEY=
# VITE_JSONBIN_BIN_ID=
# VITE_JSONBIN_API_KEY=
